# SERVIDOR PRINCIPAL: HTTP -> HTTPS REDIRECT
server {
    if ($host = www.kainanteh.es) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    if ($host = kainanteh.es) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name kainanteh.es www.kainanteh.es;
    return 301 https://$server_name$request_uri;
}

# SERVIDOR 1: KICK (HTTPS en puerto 443)
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name kainanteh.es www.kainanteh.es;
    ssl_certificate /etc/letsencrypt/live/kainanteh.es/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/kainanteh.es/privkey.pem; # managed by Certbot

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384;

    # Directorio raíz global heredado por todas las rutas (incluyendo PHP)
    root /var/www/html;

    # Servir HTML simple en la raíz
    location / {
        index index.html index.htm index.php;
    }

    # ✅ NUEVO: PROCESAR ARCHIVOS PHP CON PHP-FPM
    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        
        # Por defecto intenta conectar con PHP 8.1-FPM. 
        # Si tu VPS usa PHP 8.2 o PHP 8.3, simplemente comenta la línea de 8.1 y descomenta la que corresponda:
        fastcgi_pass unix:/var/run/php/php8.1-fpm.sock;
        # fastcgi_pass unix:/var/run/php/php8.2-fpm.sock;
        # fastcgi_pass unix:/var/run/php/php8.3-fpm.sock;
    }

